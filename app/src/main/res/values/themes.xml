<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.SteadyDose" parent="android:Theme.Material.Light.NoActionBar" >

        <!-- Material 3 color roles — light mode -->
        <item name="colorPrimary">@color/primary_light</item>

        <item name="colorError">@color/error_light</item>
           <item name="android:colorBackground">@color/background_light</item>
        <!-- Window -->
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">false</item>

        <!-- Status bar — light background so icons are dark -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation bar — matches surface color -->
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Soft keyboard behavior — content resizes -->
        <item name="android:windowSoftInputMode">adjustResize</item>

        <!-- Ripple / state layers — let Material 3 handle these -->
        <item name="android:colorControlHighlight">@color/ripple_light</item>

    </style>
    <style name="Theme.SteadyDose.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/primary_teal</item>

        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_transparent_icon</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/primary_teal</item>

        <item name="postSplashScreenTheme">@style/Theme.SteadyDose</item>
    </style>
</resources>